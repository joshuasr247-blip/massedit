# MassEdit Backend Environment Configuration

# Anthropic API Key (required)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-key-here

# Storage path for clips, thumbnails, and outputs
MASSEDIT_STORAGE_PATH=./storage

# Maximum concurrent render jobs
# Adjust based on system resources (CPU cores, RAM)
MASSEDIT_MAX_CONCURRENT_RENDERS=3

# Maximum total output count per project
# Safety limit to prevent combinatorial explosion
MASSEDIT_MAX_OUTPUT_COUNT=5000

# Database URL (optional, defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./massedit.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname

# Server configuration (optional)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# LOG_LEVEL=INFO
